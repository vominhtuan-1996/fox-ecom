{
  "name": "fox-ecom",
  "version": "0.1.0",
  "description": "React Native SDK for e-commerce",
  "_comment": "main field disabled for development - Metro uses watchFolders",
  "files": [
    "dist",
    "dist/assets",
    "dist/assets/icons",
    "dist/assets/icons/v2",
    "package.json"
  ],
  "scripts": {
    "build": "tsc --skipLibCheck --forceConsistentCasingInFileNames false || true && node scripts/build-assets.js && node resolve-aliases.js && npm pack || true",
    "build:dev": "tsc --sourceMap --skipLibCheck || true",
    "clean": "rm -rf dist *.tgz",
    "lint": "eslint src __tests__ --ext .ts,.tsx",
    "lint:fix": "eslint src __tests__ --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "pack": "npm pack"
  },
  "keywords": [
    "react-native",
    "sdk",
    "e-commerce"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@react-native/babel-preset": "^0.75.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.75.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.40.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.0",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-native": "^4.0.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "prettier": "^2.8.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "babel-loader": "^8.4.1",
    "react-native-safe-area-context": "^5.8.0",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/slider": "^5.2.0",
    "react-native-reanimated": "^4.5.0",
    "react-native-worklets": "^0.10.0",
    "react-native-gesture-handler": "^3.0.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "react-native-svg": "^15.15.5",
    "@storybook/addon-ondevice-controls": "^10.4.7",
    "@storybook/addon-ondevice-actions": "^10.4.7",
    "@storybook/react-native": "^10.4.7",
    "@storybook/react-native-ui-lite": "^10.4.7",
    "storybook": "^10.4.6",
    "react-dom": "^18.2.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts"
}
