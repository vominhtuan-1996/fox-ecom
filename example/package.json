{
  "name": "fox-ecom-example",
  "version": "0.1.0",
  "description": "Fox eCommerce SDK Example App - Demonstrates all SDK features",
  "private": true,
  "main": "index.js",
  "scripts": {
    "postinstall": "patch-package",
    "start": "NODE_OPTIONS=--openssl-legacy-provider react-native start",
    "ios": "NODE_OPTIONS=--openssl-legacy-provider react-native run-ios --simulator='iPhone 17 Pro'",
    "ios-build": "cd ios && xcodebuild -workspace FoxEcomExample.xcworkspace -scheme FoxEcomExample -configuration Release -derivedDataPath build",
    "ios-release": "cd ios && xcodebuild -workspace FoxEcomExample.xcworkspace -scheme FoxEcomExample -configuration Release -derivedDataPath build | xcpretty",
    "android": "react-native run-android",
    "android-build": "cd android && ./gradlew assembleRelease",
    "android-build-apk": "cd android && ./gradlew bundleRelease",
    "build": "npm run android-build && npm run ios-build",
    "clean": "rm -rf node_modules && npm install",
    "clean-android": "cd android && ./gradlew clean",
    "clean-ios": "cd ios && rm -rf build && rm -rf Pods && rm -rf Podfile.lock",
    "clean-all": "npm run clean-android && npm run clean-ios && npm run clean",
    "lint": "eslint src/**/*.ts src/**/*.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native-async-storage/async-storage": "^1.18.1",
    "fox-ecom": "file:../fox-ecom-0.1.0.tgz",
    "hermes-engine": "^0.11.0",
    "invariant": "^2.2.4",
    "metro-react-native-babel-transformer": "^0.77.0",
    "react": "18.3.1",
    "react-native": "0.77.3",
    "react-native-svg": "^15.15.5",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native/babel-preset": "0.77.3",
    "@react-native/eslint-config": "0.77.3",
    "@react-native/metro-config": "0.77.3",
    "@react-native/typescript-config": "0.77.3",
    "@types/react": "^18.2.6",
    "@types/react-native": "^0.73.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "patch-package": "^8.0.1",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
